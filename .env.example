# RSS Collection Settings
DART_POLL_INTERVAL_SEC=300
FSC_POLL_INTERVAL_SEC=600
DART_WATCHLIST=00123456,00654321,00987654

# Email Settings (Optional - graceful skip if not configured)
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_app_password
ALERT_EMAIL=alerts@company.com

# Watchtower (Step 2) — single-user MVP. Replace with corporate email in prod.
WATCHTOWER_ADMIN_EMAIL=admin@watchtower.local

# Watchtower (Step 4) — base URL embedded into outbound emails.
# In prod replace with the canonical UI host, e.g. https://watchtower.shinhan.local
WATCHTOWER_UI_BASE=http://localhost:8000

# System Settings
LOG_LEVEL=INFO
DEBUG=false
APP_NAME=claude_webcroll
